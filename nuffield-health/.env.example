# Nuffield Health Consultant Profile Quality Scraper
# Copy this file to .env and fill in the values

# API Keys
APIM_SUBSCRIPTION_KEY=your_apim_subscription_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database — Local SQLite (default for local dev)
DATABASE_PATH=data/nuffield.db

# Database — Turso (for Vercel / production)
# When set, overrides local SQLite. Get credentials from https://turso.tech
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# HTML Cache
HTML_CACHE_PATH=data/html-cache

# Rate Limiting
SCRAPE_DELAY_MS=1500
API_DELAY_MS=500
BOOKING_API_CONCURRENCY=3

# Search API (Tavily — 1,000 free queries/month)
TAVILY_API_KEY=your_tavily_api_key_here

# Data Governance
DATA_RETENTION_DAYS=90
EXPORT_INCLUDE_CONTACT_DATA=false
